# .gitignore for the screenshots/ folder (this file is copied in as .gitignore).
#
# What stays OUT of git:
#   - node_modules/       local Playwright install (see README — this folder is
#                         installed in isolation, never added to a monorepo).
#   - .screenshots-auth/  secrets.env + <part>.storageState.json — NEVER commit.
#   - **/*.png            the screenshots themselves (regenerated by capture.mjs).
#   - .logs/              per-run dev-server stdout/stderr.
#
# What stays IN git: screenshots.config.jsonc, capture.mjs, generate.mjs,
# package.json, README.md, gallery.html, capture-manifest.json.

node_modules/
.screenshots-auth/
**/*.png
.logs/
